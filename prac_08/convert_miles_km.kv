BoxLayout:
    orientation: 'vertical'
    BoxLayout:
        TextInput:
            id: user_input
            text: ''
            font_size: 48
            on_text: app.handle_calculate(user_input.text)
        BoxLayout:
            orientation: 'vertical'
            size_hint_x: 0.25
            Button:
                text: 'Up'
                on_press: app.handle_update(user_input.text, 1)
            Button:
                text: 'Down'
                on_press: app.handle_update(user_input.text, -1)
    Button:
        text: 'Convert miles to km'
        on_press: app.handle_calculate(user_input.text)
    Label:
        id: output_label
        text: app.user_input
        color: 0.965, 0.922, 0.078, 1
