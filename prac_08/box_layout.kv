BoxLayout:
    orientation: 'vertical'
    Button:
        text: 'Clear'
        on_press: app.handle_clear()
    TextInput:
        id: input_name
        text: ''
    Button:
        text: 'Greet'
        on_press: app.handle_greet()
    Label:
        text: 'Greetings'
        id: greeting_label
        color: (1, 1, 0, 1)